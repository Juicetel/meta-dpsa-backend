<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS HttpPlatformHandler config for the DPSA FastAPI backend.

  Topology: backend runs ONLY on 127.0.0.1:8080 (loopback). The IIS site
  binding must be http://127.0.0.1:8080 with no host header. Nothing
  outside the box should reach this site directly; the Nuxt frontend
  on the same machine calls it server-to-server.

  Single worker is deliberate. The current session_store backend keeps
  multi-turn conversation state in-process; multiple Uvicorn workers
  would split traffic across processes and lose context. Raise the
  worker count only after a shared session store (redis or postgres)
  is implemented in tools/session_store.py.

  Environment variables (set in IIS Manager > site > Configuration Editor
  > system.webServer/httpPlatform/environmentVariables):
    GROQ_API_KEY              required
    AWS_SEARCH_URL            required
    ALLOWED_ORIGINS           https://www.dpsa.gov.za (or whatever parent
                              site origin the frontend Application is
                              mounted under)
    GOOGLE_CREDENTIALS_JSON   single-line GCP service-account JSON, or
                              omit the variable entirely. Do NOT set to
                              "N/A" or other non-JSON placeholder.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  startupTimeLimit="120"
                  startupRetryCount="3"
                  processPath="%SystemDrive%\inetpub\dpsa\backend\venv\Scripts\python.exe"
                  arguments="-m uvicorn api.main:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT% --workers 1">
      <environmentVariables>
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
        <environmentVariable name="PYTHONPATH" value="%SystemDrive%\inetpub\dpsa\backend" />
        <!--
          Secrets below are intentionally blank in source control.
          Populate via IIS Configuration Editor on the server.
        -->
        <environmentVariable name="GROQ_API_KEY" value="" />
        <environmentVariable name="GOOGLE_CREDENTIALS_JSON" value="" />
        <environmentVariable name="AWS_SEARCH_URL" value="" />
        <environmentVariable name="ALLOWED_ORIGINS" value="https://www.dpsa.gov.za" />
        <environmentVariable name="GROQ_MODEL" value="llama-3.3-70b-versatile" />
        <environmentVariable name="GROQ_VISION_MODEL" value="meta-llama/llama-4-scout-17b-16e-instruct" />
        <environmentVariable name="LOG_LEVEL" value="INFO" />
        <environmentVariable name="SESSION_STORE_BACKEND" value="memory" />
      </environmentVariables>
    </httpPlatform>

    <security>
      <requestFiltering>
        <!-- Allow JSON bodies up to ~20MB for base64 image uploads -->
        <requestLimits maxAllowedContentLength="20971520" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
