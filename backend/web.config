<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS HttpPlatformHandler config for the DPSA FastAPI backend.

  Hosts: api/main.py (FastAPI) under Uvicorn with 4 worker processes
         to take advantage of the 32GB server.

  Required IIS components:
    - HttpPlatformHandler module (download from microsoft.com/iis)

  Required environment variables (set via IIS > Configuration Editor >
  system.webServer/httpPlatform/environmentVariables, OR via the App Pool
  identity's user environment):
    GROQ_API_KEY
    GOOGLE_CREDENTIALS_JSON   (preferred on Windows Server — single-line JSON)
    AWS_SEARCH_URL
    ALLOWED_ORIGINS           (comma-separated frontend origins)

  Notes:
    - %HTTP_PLATFORM_PORT%  is injected by IIS at startup.
    - processPath points at the embedded venv's python.exe; adjust if you
      deploy the wheelhouse to a different location.
    - stdoutLogEnabled writes uvicorn stdout/stderr to .\logs\stdout*.log
      under the site root for diagnostics.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  startupTimeLimit="120"
                  startupRetryCount="3"
                  processPath="%SystemDrive%\inetpub\dpsa\backend\venv\Scripts\python.exe"
                  arguments="-m uvicorn api.main:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT% --workers 4">
      <environmentVariables>
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
        <environmentVariable name="PYTHONPATH" value="%SystemDrive%\inetpub\dpsa\backend" />
        <!--
          The secrets below are intentionally blank in source control.
          Populate them in IIS Manager > Configuration Editor, or set them
          on the App Pool identity. NEVER commit real values here.
        -->
        <environmentVariable name="GROQ_API_KEY" value="" />
        <environmentVariable name="GOOGLE_CREDENTIALS_JSON" value="" />
        <environmentVariable name="AWS_SEARCH_URL" value="" />
        <environmentVariable name="ALLOWED_ORIGINS" value="" />
        <environmentVariable name="GROQ_MODEL" value="llama-3.3-70b-versatile" />
        <environmentVariable name="GROQ_VISION_MODEL" value="meta-llama/llama-4-scout-17b-16e-instruct" />
        <environmentVariable name="LOG_LEVEL" value="INFO" />
        <environmentVariable name="SESSION_STORE_BACKEND" value="memory" />
      </environmentVariables>
    </httpPlatform>

    <security>
      <requestFiltering>
        <!-- Allow JSON bodies up to ~20MB to accommodate base64 image uploads -->
        <requestLimits maxAllowedContentLength="20971520" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
