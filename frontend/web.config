<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS HttpPlatformHandler config for the DPSA Nuxt 4 frontend (Nitro server).

  After `nuxi build`, this file is intended to live inside .output/ so the
  Nitro entry point is reachable as:
      node.exe .\.output\server\index.mjs

  Required IIS components:
    - HttpPlatformHandler module
    - Node.js for Windows (LTS, on the system PATH)

  Required environment variables (set in IIS Configuration Editor or on the
  App Pool identity):
    NUXT_PUBLIC_API_BASE   e.g. http://localhost:8080
    NUXT_SESSION_PASSWORD  >= 32 random bytes (rotate from dev value!)
    NITRO_PORT             (auto-bound to %HTTP_PLATFORM_PORT% below)
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  startupTimeLimit="60"
                  startupRetryCount="3"
                  processPath="node.exe"
                  arguments=".\.output\server\index.mjs">
      <environmentVariables>
        <!-- Nitro reads PORT / NITRO_PORT to bind. HttpPlatformHandler
             injects %HTTP_PLATFORM_PORT% per request — forward it. -->
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="NITRO_PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="HOST" value="127.0.0.1" />
        <environmentVariable name="NODE_ENV" value="production" />

        <!-- Points the Nitro server at the FastAPI backend on port 8080. -->
        <environmentVariable name="NUXT_PUBLIC_API_BASE" value="http://localhost:8080" />

        <!-- Secrets: populate via IIS Configuration Editor on the server.
             Do NOT commit real values. -->
        <environmentVariable name="NUXT_SESSION_PASSWORD" value="" />
      </environmentVariables>
    </httpPlatform>

    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="20971520" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
