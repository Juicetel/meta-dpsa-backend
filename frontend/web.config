<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS HttpPlatformHandler config for the DPSA Nuxt 4 frontend (Nitro server).

  This file ships inside frontend/Nuxt/ alongside .output server/public bundles
  in the production package. On the server, the contents go to
  C:\inetpub\dpsa\frontend\ and are mounted as an IIS Application at
  /chatbot/ under the existing www.dpsa.gov.za site.

  The Nitro server binds to 127.0.0.1:%HTTP_PLATFORM_PORT% and IIS forwards
  all /chatbot/* requests to it. The browser only ever sees the public
  www.dpsa.gov.za origin — same-origin, no CORS, no cross-cert.

  Required IIS components:
    - HttpPlatformHandler module
    - Node.js LTS on the system PATH

  Environment variables (set per-Application in IIS Configuration Editor
  > system.webServer/httpPlatform/environmentVariables):
    NUXT_SESSION_PASSWORD     required, >= 32 random bytes
    NUXT_PUBLIC_API_BASE      http://127.0.0.1:8080 (default below works
                              if backend is on the same box)
    NUXT_APP_BASE_URL         /chatbot/ — must match the IIS Application
                              path AND the app.baseURL Nuxt was built with
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  startupTimeLimit="60"
                  startupRetryCount="3"
                  processPath="node.exe"
                  arguments=".\server\index.mjs">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="NITRO_PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="HOST" value="127.0.0.1" />
        <environmentVariable name="NODE_ENV" value="production" />

        <!-- Nuxt was built with app.baseURL = '/chatbot/'; keep this in sync. -->
        <environmentVariable name="NUXT_APP_BASE_URL" value="/chatbot/" />

        <!-- Server-to-server call to FastAPI on the same machine. -->
        <environmentVariable name="NUXT_PUBLIC_API_BASE" value="http://127.0.0.1:8080" />

        <!-- Populate via IIS Configuration Editor; do NOT commit a real value. -->
        <environmentVariable name="NUXT_SESSION_PASSWORD" value="" />
      </environmentVariables>
    </httpPlatform>

    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="20971520" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
