# Password for nuxt-auth-utils (minimum 32 characters)
NUXT_SESSION_PASSWORD=

# URL of the running DPSA Python pipeline API (required)
DPSA_API_URL=http://localhost:8000

# GitHub OAuth client ID (optional)
NUXT_OAUTH_GITHUB_CLIENT_ID=
# GitHub OAuth client secret (optional)
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# Vercel AI Gateway key — no longer required, DPSA pipeline handles all AI
# AI_GATEWAY_API_KEY=

# Postgres database url (optional — SQLite used by default in dev)
DATABASE_URL=
# Blob read write token (optional — local filesystem used by default in dev)
BLOB_READ_WRITE_TOKEN=
