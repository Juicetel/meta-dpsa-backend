# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key — https://console.groq.com
GROQ_API_KEY=

# Google Cloud service account credentials
# LOCAL: path to your downloaded service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# CLOUD (Render): paste the full JSON content as a single line
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Document search endpoint (provided by the AWS team)
AWS_SEARCH_URL=http://13.247.229.2:8000/api/documents/search/

# ── Optional overrides ────────────────────────────────────────────────────────

# LLM models
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Pipeline tuning
MAX_RETRIEVAL_CHUNKS=5
MAX_FOLLOWUPS=3
RETRIEVER_TIMEOUT=10
LOG_LEVEL=INFO
